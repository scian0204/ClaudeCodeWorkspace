# ── Claude ────────────────────────────────────────────────
# Token precedence per turn: the author's OWN registered token → the admin-managed
# common token (set in the admin panel, encrypted in the DB) → this env fallback → mock.
# Prefer setting the common token from the admin panel; this env is only a bootstrap
# fallback used before an admin sets one. Accepts BOTH:
#   • a plain API key   → sk-ant-api...  (console.anthropic.com)
#   • an OAuth token     → sk-ant-oat...  (`claude setup-token`, Pro/Max login)
# The server auto-detects the prefix and wires the right env var for the CLI.
ANTHROPIC_API_KEY=
# Force mock for EVERY turn regardless of any token (dev): 1 | 0
MOCK_CLAUDE=0
# Key material for encrypting stored Claude tokens at rest (AES-256-GCM).
# CHANGE THIS in production. If empty, falls back to SESSION_SECRET. Changing it
# invalidates all stored tokens (users/admin re-register).
TOKEN_ENC_SECRET=change-me-token-encryption-secret
# Path to the claude-code executable (optional; SDK bundles one).
# CLAUDE_CODE_PATH=

# ── Server ────────────────────────────────────────────────
PORT=3000
# Where all tiers live (bind-mounted / named volume in Docker).
DATA_DIR=./data
# Session cookie signing secret. CHANGE THIS.
SESSION_SECRET=change-me-please-super-secret
# Global concurrent-turn cap across all sessions (shared key throttle).
MAX_CONCURRENT_TURNS=3
# First-boot admin bootstrap (created only if no users exist).
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=admin
# HTTPS (optional). Required for PWA "Install as app" off-localhost — browsers only
# treat localhost as a secure context. Point these at a browser-trusted cert (mkcert
# for LAN/IP, or Let's Encrypt with a domain); empty = plain HTTP. See README.
# TLS_KEY=/certs/key.pem
# TLS_CERT=/certs/cert.pem

# ── code-server ───────────────────────────────────────────
# Docker image used for editor containers.
CODE_SERVER_IMAGE=codercom/code-server:latest
# Idle timeout (ms) before a code-server container is reaped.
CODE_SERVER_IDLE_MS=1800000
# Docker network the app + code-server siblings share (compose sets this).
CODE_SERVER_NETWORK=
# Named volume holding /data on the host (for sibling mounts). In compose this
# is the project volume name, e.g. claudecode-workspace_data.
DATA_VOLUME=
