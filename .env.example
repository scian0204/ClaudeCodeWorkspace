# ── Claude ────────────────────────────────────────────────
# Shared single credential (v1). If empty, server runs in MOCK_CLAUDE mode
# (echo agent) so the whole app is still runnable/demoable without a key.
# Accepts BOTH:
#   • a plain API key   → sk-ant-api...  (console.anthropic.com)
#   • an OAuth token     → sk-ant-oat...  (`claude setup-token`, Pro/Max login)
# The server auto-detects the prefix and wires the right env var for the CLI.
ANTHROPIC_API_KEY=
# Force mock even when a key is present (dev): 1 | 0
MOCK_CLAUDE=0
# Path to the claude-code executable (optional; SDK bundles one).
# CLAUDE_CODE_PATH=

# ── Server ────────────────────────────────────────────────
PORT=3000
# Where all tiers live (bind-mounted / named volume in Docker).
DATA_DIR=./data
# Session cookie signing secret. CHANGE THIS.
SESSION_SECRET=change-me-please-super-secret
# Global concurrent-turn cap across all sessions (shared key throttle).
MAX_CONCURRENT_TURNS=3
# First-boot admin bootstrap (created only if no users exist).
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=admin

# ── code-server ───────────────────────────────────────────
# Docker image used for editor containers.
CODE_SERVER_IMAGE=codercom/code-server:latest
# Idle timeout (ms) before a code-server container is reaped.
CODE_SERVER_IDLE_MS=1800000
# Docker network the app + code-server siblings share (compose sets this).
CODE_SERVER_NETWORK=
# Named volume holding /data on the host (for sibling mounts). In compose this
# is the project volume name, e.g. claudecode-workspace_data.
DATA_VOLUME=
